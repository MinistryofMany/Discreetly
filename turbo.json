{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate": { "cache": false },
    "build": {
      "dependsOn": ["^build", "^generate", "generate"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": { "cache": false, "persistent": true },
    "lint": {},
    "typecheck": { "dependsOn": ["^build", "^generate", "generate"] },
    "test": { "dependsOn": ["^build", "^generate", "generate"] }
  }
}
