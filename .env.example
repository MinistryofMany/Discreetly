DATABASE_URL="postgresql://discreetly:discreetly@localhost:5432/discreetly?schema=public"
REDIS_URL="redis://localhost:6379"
# The HOST of MINISTER_ISSUER must equal Minister's MINISTER_ISSUER_DOMAIN.
# The SDK derives the expected badge VC issuer (did:web:<host>) from this URL;
# if the host differs from the domain Minister stamps its VCs with, every badge
# is rejected (fails closed - login still works, but no badge ever counts).
MINISTER_ISSUER="http://localhost:3000"
# Optional fail-fast cross-check of the coupling above: set this to the DID
# Minister actually stamps (did:web:<Minister's MINISTER_ISSUER_DOMAIN>) and
# the API refuses to boot if the DID derived from MINISTER_ISSUER differs,
# instead of silently rejecting every badge at runtime.
# MINISTER_VC_ISSUER="did:web:localhost%3A3000"
MINISTER_CLIENT_ID="discreetly_dev"
# Per-room disclosure (Phase 3 / Path B) runs the SDK auth-code+PKCE flow at
# dedicated RP routes, which need the client secret for the token exchange and a
# fixed redirect URI registered with Minister. The global header login (Auth.js
# `ministerProvider`) shares the same secret.
MINISTER_CLIENT_SECRET="discreetly_dev_secret_2026"
API_PORT="3002"
ALLOWED_WS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:5173"
# Operator (admin) allowlist: comma-separated Minister pairwise subs. A signed-in
# user whose verified id_token sub is in this list is the operator (/admin, all
# admin.* procedures). FAILS CLOSED: unset or empty means NO operator exists.
# Find your sub on /identity (or the /admin "not authorized" panel) after
# signing in - it is pairwise per app, so it must be the sub THIS app sees.
# DISCREETLY_OPERATOR_SUBS="mnstr_pairwise_sub_1,mnstr_pairwise_sub_2"
