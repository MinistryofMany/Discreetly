{
  "name": "@discreetly/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "validate": "dotenv -e ../../.env -- prisma validate",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(no lint configured)\"",
    "test": "dotenv -e ../../.env -- vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
