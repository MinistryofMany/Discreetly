generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomVisibility {
  PUBLIC
  PRIVATE
}

enum RoomPersistence {
  PERSISTENT
  EPHEMERAL
}

enum RoomEncryption {
  PLAINTEXT
  AES
}

enum MembershipStatus {
  ACTIVE
  BANNED
}

enum BanReason {
  RATE_LIMIT_COLLISION
  ADMIN
}

model Room {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  description      String?
  rlnIdentifier    String          @unique
  rateLimit        Int
  userMessageLimit Int
  maxDevices       Int             @default(5)
  visibility       RoomVisibility  @default(PUBLIC)
  persistence      RoomPersistence @default(PERSISTENT)
  encryption       RoomEncryption  @default(PLAINTEXT)
  passwordHash     String?
  accessPolicy     Json
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  memberships Membership[]
  leaves      MembershipLeaf[]
  messages    Message[]
  bans        Ban[]
}

model Membership {
  id            String           @id @default(cuid())
  roomId        String
  room          Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  joinNullifier String
  status        MembershipStatus @default(ACTIVE)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  leaves MembershipLeaf[]

  @@unique([roomId, joinNullifier])
  @@index([roomId, status])
}

model MembershipLeaf {
  id                 String     @id @default(cuid())
  membershipId       String
  membership         Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  roomId             String
  room               Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  identityCommitment String
  rateCommitment     String
  deviceLabel        String?
  createdAt          DateTime   @default(now())
  revokedAt          DateTime?

  @@unique([roomId, rateCommitment])
  @@index([membershipId])
}

model Ban {
  id             String    @id @default(cuid())
  roomId         String
  room           Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  joinNullifier  String?
  rateCommitment String?
  reason         BanReason
  shamirSecret   String?
  createdAt      DateTime  @default(now())

  @@index([roomId, joinNullifier])
  @@index([roomId, rateCommitment])
}

model Message {
  id           String   @id @default(cuid())
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  epoch        BigInt
  rlnNullifier String
  content      String
  proof        Json
  sessionColor String?
  createdAt    DateTime @default(now())
  // Operator soft-delete (tombstone). When deletedAt is set, the message has
  // been removed by the platform operator: `content` and `sessionColor` are
  // purged in place and the row renders as "removed by operator". `rlnNullifier`,
  // `epoch`, and `proof` are intentionally RETAINED so RLN rate-limit collision
  // detection (collision.ts) still works for the message's (room, epoch,
  // nullifier). `deletedBy` is the operator's Minister pairwise sub.
  deletedAt    DateTime?
  deletedBy    String?

  @@unique([roomId, epoch, rlnNullifier])
  @@index([roomId, epoch])
  // Ordered prune (newest-1000 ring buffer) and newest-first history reads.
  @@index([roomId, createdAt])
}

model AdminUser {
  id          String   @id @default(cuid())
  pairwiseSub String   @unique
  label       String?
  createdAt   DateTime @default(now())
}

/// Per-room SDK disclosure flow state (Phase 3 / Path B). The RP "start join"
/// route mints PKCE+state+nonce, persists them here keyed by `state`, and
/// redirects to Minister's authorize endpoint carrying `minister_policy`. The
/// `redirectUri` callback looks the row up by `state` (delete-on-read of the
/// pre-exchange secrets), runs `exchangeCode`, and stores the verified, fresh
/// per-room `idToken` back on the SAME row, then redirects the browser to the
/// room with the row `id` as an unguessable single-use pickup token. The client
/// picks the token up once (`/api/room-auth/token`, which deletes the row) and
/// forwards it to `membership.join`. Rows are short-lived and single-use; expiry
/// is enforced server-side. Carries no durable badge data - only the live token
/// for the in-flight join.
model RoomAuthFlow {
  /// Unguessable, server-generated. Doubles as the post-callback pickup token.
  id          String   @id @default(cuid())
  /// OIDC `state`; the callback's lookup key. Unique so a forged/duplicate
  /// state can never collide with an in-flight flow.
  state       String   @unique
  /// OIDC `nonce` the SDK binds the id_token to; checked at `exchangeCode`.
  nonce       String
  /// PKCE S256 verifier; consumed at the token exchange. Nulled after exchange.
  codeVerifier String?
  /// The room this disclosure flow is for; the join target after callback.
  roomId      String
  /// The verified, fresh per-room id_token, set by the callback after a
  /// successful `exchangeCode`. Null until the callback completes.
  idToken     String?  @db.Text
  createdAt   DateTime @default(now())
  /// Hard server-side TTL; an expired row is rejected and cleaned up.
  expiresAt   DateTime

  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actor])
  @@index([action])
}

// Auth.js v5 database-session models, consumed by `@auth/prisma-adapter` in
// `apps/web`. The web app stores login sessions as opaque Session rows (cookie
// holds only the sessionToken); the Account row persists the Minister OAuth
// tokens (including `id_token`) at sign-in. Field names are the canonical names
// the adapter requires verbatim - do not rename. These are unrelated to the
// `AdminUser` model above (admin authorization, keyed on Minister pairwise sub).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
