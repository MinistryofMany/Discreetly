# Production docker-compose environment.
# Copy to `.env.prod` and fill in real values. `.env.prod` is gitignored; never
# commit real secrets. Used by:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ---- Postgres (internal to the compose network; not published to the host) ----
POSTGRES_USER=discreetly
# IMPORTANT: set POSTGRES_PASSWORD to a strong random value, then copy the
# exact same password into DATABASE_URL below. Both must match or the API will
# fail to connect to Postgres.
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD
POSTGRES_DB=discreetly

# ---- API <-> datastores (host = compose service names on the internal net) ----
# The password in DATABASE_URL must match POSTGRES_PASSWORD above exactly.
DATABASE_URL=postgresql://discreetly:REPLACE_ME_STRONG_PASSWORD@postgres:5432/discreetly?schema=public
REDIS_URL=redis://redis:6379

# ---- Minister OIDC (external provider) ----
# To reach a Minister running on the host machine from inside compose, use
# host.docker.internal:3000 (the api/web services map it to the host gateway).
# WARNING: the HOST of MINISTER_ISSUER must equal Minister's
# MINISTER_ISSUER_DOMAIN. The SDK derives the expected badge VC issuer
# (did:web:<host>) from this URL, so a host like host.docker.internal that does
# NOT match the domain Minister stamps its VCs with causes EVERY badge to be
# rejected (fails closed - login still works, but no badge ever counts).
# In a real deployment, point this at Minister's public issuer URL whose host
# matches its MINISTER_ISSUER_DOMAIN.
MINISTER_ISSUER=http://host.docker.internal:3000
# STRONGLY RECOMMENDED in production: the fail-fast cross-check for the warning
# above. Set to the DID Minister stamps into its VCs (did:web:<Minister's
# MINISTER_ISSUER_DOMAIN>); the API then refuses to boot when the DID derived
# from MINISTER_ISSUER's host differs, instead of silently rejecting every
# badge at runtime.
# MINISTER_VC_ISSUER=did:web:ministry.id
MINISTER_CLIENT_ID=discreetly
MINISTER_CLIENT_SECRET=change-me-minister-client-secret

# ---- API listener + WS origin allowlist ----
# Must include the web origin so the browser WS handshake is accepted.
API_PORT=3002
ALLOWED_WS_ORIGINS=http://localhost:3001

# ---- Auth.js (web, runtime) ----
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# ---- Public API origins (web, BUILD-TIME inlined into the client bundle) ----
# Changing these requires rebuilding the web image. They are passed as build
# args to apps/web/Dockerfile and must point at where the browser reaches the API.
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_API_WS_URL=ws://localhost:3002

# ---- Host port mappings (dev stack already uses 5432/6379) ----
# Postgres and Redis are internal-only. Only web + api are published.
WEB_HOST_PORT=3001
API_HOST_PORT=3002
