AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST=true
# Database-strategy Auth.js sessions: the web app's Prisma adapter reads/writes
# Session + Account rows in the same Postgres the API uses. Point this at the
# same database as the root .env DATABASE_URL.
DATABASE_URL="postgresql://discreetly:discreetly@localhost:5432/discreetly?schema=public"
# The HOST of MINISTER_ISSUER must equal Minister's MINISTER_ISSUER_DOMAIN.
# The SDK derives the expected badge VC issuer (did:web:<host>) from this URL;
# if the host differs from the domain Minister stamps its VCs with, every badge
# is rejected (fails closed - login still works, but no badge ever counts).
MINISTER_ISSUER="http://localhost:3000"
MINISTER_CLIENT_ID="discreetly_dev"
MINISTER_CLIENT_SECRET="your-minister-client-secret"
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_API_WS_URL="ws://localhost:3002"
