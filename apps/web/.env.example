AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST=true
# Database-strategy Auth.js sessions: the web app's Prisma adapter reads/writes
# Session + Account rows in the same Postgres the API uses. Point this at the
# same database as the root .env DATABASE_URL.
DATABASE_URL="postgresql://discreetly:discreetly@localhost:5432/discreetly?schema=public"
# The HOST of MINISTER_ISSUER must equal Minister's MINISTER_ISSUER_DOMAIN.
# The SDK derives the expected badge VC issuer (did:web:<host>) from this URL;
# if the host differs from the domain Minister stamps its VCs with, every badge
# is rejected (fails closed - login still works, but no badge ever counts).
MINISTER_ISSUER="http://localhost:3000"
MINISTER_CLIENT_ID="discreetly_dev"
MINISTER_CLIENT_SECRET="your-minister-client-secret"
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_API_WS_URL="ws://localhost:3002"

# -- Ministry anonymous-identity handoff (optional; anon-identity spec 9.2) ---
# Discreetly's own mix secret for deriving users' anonymous-identity device
# seeds from the Ministry handoff. Only exercised when Minister delivers a
# #minister_anon fragment on the OIDC redirect (i.e. the Discreetly OIDC
# client has anonAppId set on the Minister side). When unset, the handoff is
# disabled FAIL-CLOSED: login is unaffected and identities keep being
# generated locally, exactly as before.
#
# Provision ONCE with: openssl rand -hex 32   (>= 32 CSPRNG bytes, hex), then
# BACK IT UP with the same durability as the database and NEVER regenerate or
# rotate it (spec invariant I9): this value is identity-determining - a
# changed value silently forks EVERY user's anonymous identity (every room
# membership and message authorship orphans, with no error anywhere). Exclude
# it from any secret-rotation runbook.
#
# Recovery story (spec 9.2 - write down where the backup lives BEFORE
# enabling the flow): for the Ministry prod deployment, the source of truth
# is an AWS SSM SecureString alongside the other Discreetly prod secrets; the
# Lightsail box's compose env file holds only a copy. Restoring = reading the
# SSM parameter back into the env. Anyone with prod SSM read access can
# restore it. For any other deployment, record the equivalent location here.
#
# The value is delivered per request to signed-in browsers via
# /api/minister-anon/rp-mix (never baked into the public bundle); the client
# mixes it (HKDF salt) into the per-user Ministry secret - alone it derives
# nothing.
MINISTER_ANON_RP_MIX_SECRET=""
